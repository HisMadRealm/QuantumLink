#include "Bundles.xcconfig"
PRODUCT_NAME = QuantumLinkMacApp
PRODUCT_BUNDLE_IDENTIFIER = com.quantumlink.macos
INFOPLIST_FILE = Config/QuantumLinkMacApp-Info.plist
CODE_SIGN_ENTITLEMENTS = Config/QuantumLinkMacApp.entitlements
SWIFT_VERSION = 5.9
GENERATE_INFOPLIST_FILE = NO
LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/../Frameworks
ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
SKIP_INSTALL = NO
